# Sorted — environment variables.
# Copy this file to .env and fill in real values. Lines marked REQUIRED must
# be set; everything else has a working dev default.

# --- Flask ----------------------------------------------------------------
FLASK_ENV=development
FLASK_APP=wsgi.py
# REQUIRED. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-64-hex-chars

# --- Web ------------------------------------------------------------------
APP_BASE_URL=http://localhost:5000
APP_TIMEZONE=Europe/London

# --- Database -------------------------------------------------------------
# Local: matches `make db-up` defaults. Note the psycopg3 driver prefix.
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/sorted

# --- Email ----------------------------------------------------------------
# Backends: 'console' (logs to stdout, good for dev), 'memory' (tests),
# 'smtp' (real send via SMTP_*).
MAIL_BACKEND=console
MAIL_FROM=Sorted <bookings@sorted.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Stripe ---------------------------------------------------------------
# Placeholders are fine until you try a real checkout. Then put real
# pk_test_* / sk_test_* keys from https://dashboard.stripe.com/test/apikeys
# and run `stripe listen --forward-to localhost:5000/webhooks/stripe` to get
# STRIPE_WEBHOOK_SECRET.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Twilio (SMS) ---------------------------------------------------------
# Leave TWILIO_ENABLED=false in dev; the SMS service no-ops cleanly.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Sentry ---------------------------------------------------------------
# Leave SENTRY_DSN empty in dev — errors land in your Flask log.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
APP_RELEASE=dev
ENV_NAME=development

# --- Photo storage --------------------------------------------------------
# 'local' writes to instance/uploads/ and serves via /uploads/<key>. Fine
# for dev. Production should use 's3' (works with AWS S3 or Cloudflare R2).
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_PUBLIC_BASE=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
MAX_PHOTO_BYTES=10485760
MAX_PHOTOS_PER_BOOKING=3

# --- Live tracking --------------------------------------------------------
TRACKING_LINK_TTL_MINUTES=60
